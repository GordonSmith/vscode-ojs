{
    // See https://go.microsoft.com/fwlink/?LinkId=733558 
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "label": "gen-node-watch",
            "script": "gen-node-watch",
            "problemMatcher": [
                "$tsc-watch"
            ],
            "presentation": {
                "group": "group-build"
            }
        },
        {
            "type": "npm",
            "label": "gen-webview-watch",
            "script": "gen-webview-watch",
            "problemMatcher": [
                "$tsc-watch"
            ],
            "presentation": {
                "group": "group-build"
            }
        },
        {
            "type": "npm",
            "label": "build-ts-watch",
            "script": "build-ts-watch",
            "problemMatcher": [],
            "presentation": {
                "group": "group-build"
            }
        },
        {
            "label": "build",
            "dependsOn": [
                "gen-node-watch",
                "gen-webview-watch",
                "build-ts-watch"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "web-extension-server",
            "type": "shell",
            "command": "npx",
            "args": [
                "@vscode/test-web",
                "--browserType=chromium",
                "."
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "opening browser",
                    "endsPattern": "web server running"
                }
            },
            "presentation": {
                "reveal": "always",
                "group": "build"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}